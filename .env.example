# Database (host → Docker Postgres on 15432)
DATABASE_URL=postgresql://vaultops:vaultops@localhost:15432/vaultops?schema=public
# POSTGRES_HOST_PORT=15432
# REDIS_HOST_PORT=16379

REDIS_URL=redis://localhost:16379

# Auth mode: password | clerk | hybrid (default).
# hybrid = password JWT first, then Clerk when CLERK_JWKS_URL is set.
AUTH_MODE=hybrid
AUTH_JWT_SECRET=dev-only-change-me-vaultops-auth-jwt-secret-32b
EMAIL_PROVIDER=console

# Bootstrap admin — upserted on every `prisma db seed`. No public registration.
ADMIN_EMAIL=admin@webmee.tech
ADMIN_PASSWORD=ChangeMe!Admin1
ADMIN_FIRST_NAME=WebMee
ADMIN_LAST_NAME=Admin

# --- Clerk (optional; leave empty for password-only local) ---
# Web: enable ClerkProvider + /sign-in when publishable key is set.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# API: when set, Bearer JWTs are verified via JWKS and `dev-token` is rejected.
# Example: https://YOUR_INSTANCE.clerk.accounts.dev/.well-known/jwks.json
CLERK_JWKS_URL=
CLERK_ISSUER=
CLERK_AUDIENCE=
# Add custom session claim `email` in Clerk Dashboard → Sessions → Customize session token.
# When true (or AUTH_MODE=clerk), Next middleware requires a Clerk session on app routes.
NEXT_PUBLIC_AUTH_REQUIRE_CLERK=false
# When "true", web may send Bearer `dev-token` if no session JWT. Forced off once Clerk keys are set
# unless you explicitly set this to true. Omit for auto: allow only when Clerk publishable key is empty.
# NEXT_PUBLIC_ALLOW_DEV_TOKEN=

ALLOWED_EMAIL_DOMAINS=webmee.tech

AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_ENDPOINT_URL=
KMS_KEY_ID=

# API_HOST_PORT=13001
# WEB_HOST_PORT=13000
NEXT_PUBLIC_API_URL=http://localhost:13001
DEFAULT_ORGANIZATION_ID=00000000-0000-4000-8000-000000000001
LOCAL_KMS_MASTER_KEY=
WEB_ORIGIN=http://localhost:13000

# --- Sentry (staging/production) ---
# API Nest DSN
SENTRY_DSN=
# Web browser + Next server/edge (usually same project or separate web project)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ENVIRONMENT=development
# Optional: upload source maps during `next build` (CI)
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_TRACES_SAMPLE_RATE=0.1

# Backups: see docs/postgres-backup-restore.md
